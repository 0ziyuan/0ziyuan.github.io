    <item>
      <title>Foundations of Logic</title>
      <link>https://0-ziyuan.com/2020/10/12/Foundations-of-Logic/</link>
      <guid>https://0-ziyuan.com/2020/10/12/Foundations-of-Logic/</guid>
      <pubDate>Mon, 12 Oct 2020 15:26:26 GMT</pubDate>
      
      <description>&lt;p&gt;&lt;img src=&quot;https://gitee.com/wanli-0ziyuan/gitee-graph-bed/raw/master/img/20201023215732.jpg&quot;&gt;&lt;/p&gt;</description>
      
      
      
